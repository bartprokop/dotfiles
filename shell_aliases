# Navigating and inspectinf file system
if (( $+commands[lsd] )); then
  alias ls='lsd'
fi

alias ll='ls -al'

# https://github.com/seyhunak/dotfiles/blob/master/aliases.zsh

# Homebrew
alias brewu='brew update && brew upgrade && brew cleanup && brew prune && brew doctor'

# Show human friendly numbers and colors
alias df='df -h'
alias du='du -h -d 2'
